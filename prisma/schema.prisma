generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Status Publikasi
enum PublishStatus {
  DRAFT
  PUBLISHED
}

// Tabel Kategori Wisata
model Category {
  id        String         @id @default(cuid())
  name      String
  places    TourismPlace[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Tabel Destinasi Wisata
model TourismPlace {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String        @db.Text
  location    String
  mapUrl      String?
  openHours   String?
  facilities  String[]
  status      PublishStatus @default(DRAFT)
  
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  
  media       MediaFile[]
  
  createdById String?
  createdBy   Admin?        @relation("TourismPlaceCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   Admin?        @relation("TourismPlaceUpdatedBy", fields: [updatedById], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Tabel Kategori Budaya
model CultureCategory {
  id        String        @id @default(cuid())
  name      String
  items     CultureItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// Tabel Konten Budaya
model CultureItem {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  summary     String?
  description String          @db.Text
  status      PublishStatus   @default(DRAFT)

  categoryId  String
  category    CultureCategory @relation(fields: [categoryId], references: [id])

  media       MediaFile[]

  createdById String?
  createdBy   Admin?          @relation("CultureItemCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   Admin?          @relation("CultureItemUpdatedBy", fields: [updatedById], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// Tabel File Gambar/Media
model MediaFile {
  id             String        @id @default(cuid())
  url            String
  publicId       String
  type           String        @default("IMAGE")

  tourismPlaceId String?
  tourismPlace   TourismPlace? @relation(fields: [tourismPlaceId], references: [id], onDelete: Cascade)

  cultureItemId  String?
  cultureItem    CultureItem?  @relation(fields: [cultureItemId], references: [id], onDelete: Cascade)

  newsArticleId  String?
  newsArticle    NewsArticle?  @relation(fields: [newsArticleId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// Tabel Berita Desa
model NewsArticle {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String?
  content     String        @db.Text
  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?

  media       MediaFile[]

  createdById String?
  createdBy   Admin?        @relation("NewsArticleCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   Admin?        @relation("NewsArticleUpdatedBy", fields: [updatedById], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Tabel Role & Hak Akses (RBAC)
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[]
  isSystem    Boolean  @default(false) // Jika true, role tidak bisa dihapus
  admins      Admin[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Akun Administrator
model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  roleId       String?
  role         Role?     @relation(fields: [roleId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relasi Audit Trail (Pembuat & Pengubah)
  createdTourismPlaces TourismPlace[] @relation("TourismPlaceCreatedBy")
  updatedTourismPlaces TourismPlace[] @relation("TourismPlaceUpdatedBy")

  createdCultureItems  CultureItem[]  @relation("CultureItemCreatedBy")
  updatedCultureItems  CultureItem[]  @relation("CultureItemUpdatedBy")

  createdNewsArticles  NewsArticle[]  @relation("NewsArticleCreatedBy")
  updatedNewsArticles  NewsArticle[]  @relation("NewsArticleUpdatedBy")

  createdProductsUMKM  ProductUMKM[]  @relation("ProductUMKMCreatedBy")
  updatedProductsUMKM  ProductUMKM[]  @relation("ProductUMKMUpdatedBy")

  createdAnnouncements Announcement[] @relation("AnnouncementCreatedBy")
  updatedAnnouncements Announcement[] @relation("AnnouncementUpdatedBy")

  createdBudgets       VillageBudget[] @relation("VillageBudgetCreatedBy")
  updatedBudgets       VillageBudget[] @relation("VillageBudgetUpdatedBy")

  createdWaterSources  WaterSource[]  @relation("WaterSourceCreatedBy")
  updatedWaterSources  WaterSource[]  @relation("WaterSourceUpdatedBy")

  createdRegulations   VillageRegulation[] @relation("VillageRegulationCreatedBy")
  updatedRegulations   VillageRegulation[] @relation("VillageRegulationUpdatedBy")
}

enum OrderChannel {
  WHATSAPP
  SHOPEE
  TOKOPEDIA
  CUSTOM
}

// Tabel Produk UMKM
model ProductUMKM {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String        @db.Text
  price       Int
  ownerName   String
  imageUrl    String?
  orderUrl    String        @default("")
  orderType   OrderChannel  @default(WHATSAPP)
  status      PublishStatus @default(DRAFT)

  createdById String?
  createdBy   Admin?        @relation("ProductUMKMCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   Admin?        @relation("ProductUMKMUpdatedBy", fields: [updatedById], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Tabel Pengaturan Hero Section
model HeroSettings {
  id          String   @id @default("main")
  imageUrl    String   @db.Text
  tagline     String
  titleLine1  String
  titleLine2  String
  subTagline  String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tabel Central Media Asset (Galeri Media)
model MediaAsset {
  id        String   @id @default(cuid())
  url       String   @unique
  publicId  String   // uploadthing key atau "external"
  name      String?
  createdAt DateTime @default(now())
}

// Tabel Pengumuman Desa
model Announcement {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  content     String        @db.Text
  status      PublishStatus @default(DRAFT)
  imageUrl    String?       // Opsional: foto/cover pengumuman
  category    String        @default("Umum")
  createdById String?
  createdBy   Admin?        @relation("AnnouncementCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   Admin?        @relation("AnnouncementUpdatedBy", fields: [updatedById], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Tabel Profil Desa
model VillageProfile {
  id                  String   @id @default("main")
  // Sambutan Kepala Desa
  welcomeName         String   @default("Kepala Desa Nekmese")
  welcomeRole         String   @default("Kepala Desa")
  welcomeText         String   @db.Text
  welcomeImageUrl     String?
  
  // Sejarah Desa
  history             String   @db.Text
  
  // Visi & Misi
  vision              String   @db.Text
  mission             String   @db.Text
  
  // Identitas Desa
  villageCode         String   @default("53.01.xx.xxxx")
  district            String   @default("Kupang Barat")
  regency             String   @default("Kupang")
  province            String   @default("Nusa Tenggara Timur")
  establishedYear     String   @default("xxxx")
  
  // Peta dan Batas Wilayah
  boundariesNorth     String   @default("")
  boundariesEast      String   @default("")
  boundariesSouth     String   @default("")
  boundariesWest      String   @default("")
  mapUrl              String?  @db.Text
  geography           String   @db.Text
  
  // Data Kependudukan
  populationTotal     Int      @default(0)
  populationMale      Int      @default(0)
  populationFemale    Int      @default(0)
  populationFamilies  Int      @default(0)
  
  // Struktur Organisasi
  structureImageUrl   String?
  
  // Konten Lainnya
  potential           String   @db.Text
  organizations       String   @db.Text
  facilities          String   @db.Text
  achievements        String   @db.Text
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum BudgetType {
  REVENUE
  EXPENDITURE
}

model VillageBudget {
  id                          String         @id @default(cuid())
  year                        Int            @unique
  totalRevenueBudget          Float          @default(0)
  totalRevenueRealization     Float          @default(0)
  totalExpenditureBudget      Float          @default(0)
  totalExpenditureRealization Float          @default(0)
  
  items                       BudgetDetail[]
  
  createdById                 String?
  createdBy                   Admin?         @relation("VillageBudgetCreatedBy", fields: [createdById], references: [id])
  updatedById                 String?
  updatedBy                   Admin?         @relation("VillageBudgetUpdatedBy", fields: [updatedById], references: [id])
  
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
}

model BudgetDetail {
  id                String        @id @default(cuid())
  budgetId          String
  budget            VillageBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  
  type              BudgetType
  category          String
  amountBudget      Float         @default(0)
  amountRealization Float         @default(0)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ChatCache {
  id        String   @id @default(cuid())
  question  String   @unique
  answer    String   @db.Text
  category  String   @default("PROFIL")
  useCount  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tabel Titik Air
model WaterSource {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String        @db.Text
  latitude    Float
  longitude   Float
  mapUrl      String?       @db.Text
  imageUrl    String?       @db.Text
  images      String[]      @default([]) // Array foto titik air
  status      PublishStatus @default(DRAFT)
  
  createdById String?
  createdBy   Admin?        @relation("WaterSourceCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   Admin?        @relation("WaterSourceUpdatedBy", fields: [updatedById], references: [id])
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Model untuk Peraturan Desa
model VillageRegulation {
  id           String        @id @default(cuid())
  title        String        @db.Text
  number       String        // Nomor Peraturan (contoh: "02/2025")
  year         Int           // Tahun Peraturan
  description  String?       @db.Text
  type         RegulationType @default(PERATURAN_DESA)
  fileUrl      String        @db.Text
  fileKey      String?       @db.Text
  status       PublishStatus @default(DRAFT)
  
  createdById  String?
  createdBy    Admin?        @relation("VillageRegulationCreatedBy", fields: [createdById], references: [id])
  updatedById  String?
  updatedBy    Admin?        @relation("VillageRegulationUpdatedBy", fields: [updatedById], references: [id])
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum RegulationType {
  PERATURAN_DESA
  KEPUTUSAN_KEPALA_DESA
  PERATURAN_BERSAMA
}