generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Status Publikasi
enum PublishStatus {
  DRAFT
  PUBLISHED
}

// Tabel Kategori Wisata
model Category {
  id        String         @id @default(cuid())
  name      String
  places    TourismPlace[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Tabel Destinasi Wisata
model TourismPlace {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String        @db.Text
  location    String
  mapUrl      String?
  openHours   String?
  facilities  String[]
  status      PublishStatus @default(DRAFT)
  
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  
  media       MediaFile[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Tabel Kategori Budaya
model CultureCategory {
  id        String        @id @default(cuid())
  name      String
  items     CultureItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// Tabel Konten Budaya
model CultureItem {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  summary     String?
  description String          @db.Text
  status      PublishStatus   @default(DRAFT)

  categoryId  String
  category    CultureCategory @relation(fields: [categoryId], references: [id])

  media       MediaFile[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// Tabel File Gambar/Media
model MediaFile {
  id             String        @id @default(cuid())
  url            String
  publicId       String
  type           String        @default("IMAGE")

  tourismPlaceId String?
  tourismPlace   TourismPlace? @relation(fields: [tourismPlaceId], references: [id], onDelete: Cascade)

  cultureItemId  String?
  cultureItem    CultureItem?  @relation(fields: [cultureItemId], references: [id], onDelete: Cascade)

  newsArticleId  String?
  newsArticle    NewsArticle?  @relation(fields: [newsArticleId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// Tabel Berita Desa
model NewsArticle {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String?
  content     String        @db.Text
  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?

  media       MediaFile[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Role Administrator
enum AdminRole {
  SUPER_ADMIN
  ADMIN_KONTEN
  ADMIN_UMKM
}

// Akun Administrator
model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         AdminRole @default(SUPER_ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum OrderChannel {
  WHATSAPP
  SHOPEE
  TOKOPEDIA
  CUSTOM
}

// Tabel Produk UMKM
model ProductUMKM {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String        @db.Text
  price       Int
  ownerName   String
  imageUrl    String?
  orderUrl    String        @default("")
  orderType   OrderChannel  @default(WHATSAPP)
  status      PublishStatus @default(DRAFT)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Tabel Pengaturan Hero Section
model HeroSettings {
  id          String   @id @default("main")
  imageUrl    String   @db.Text
  tagline     String
  titleLine1  String
  titleLine2  String
  subTagline  String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tabel Central Media Asset (Galeri Media)
model MediaAsset {
  id        String   @id @default(cuid())
  url       String   @unique
  publicId  String   // uploadthing key atau "external"
  name      String?
  createdAt DateTime @default(now())
}

// Tabel Pengumuman Desa
model Announcement {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  content     String        @db.Text
  status      PublishStatus @default(DRAFT)
  imageUrl    String?       // Opsional: foto/cover pengumuman
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Tabel Profil Desa
model VillageProfile {
  id                  String   @id @default("main")
  // Sambutan Kepala Desa
  welcomeName         String   @default("Kepala Desa Nekmese")
  welcomeRole         String   @default("Kepala Desa")
  welcomeText         String   @db.Text
  welcomeImageUrl     String?
  
  // Sejarah Desa
  history             String   @db.Text
  
  // Visi & Misi
  vision              String   @db.Text
  mission             String   @db.Text
  
  // Identitas Desa
  villageCode         String   @default("53.01.xx.xxxx")
  district            String   @default("Kupang Barat")
  regency             String   @default("Kupang")
  province            String   @default("Nusa Tenggara Timur")
  establishedYear     String   @default("xxxx")
  
  // Peta dan Batas Wilayah
  boundariesNorth     String   @default("")
  boundariesEast      String   @default("")
  boundariesSouth     String   @default("")
  boundariesWest      String   @default("")
  mapUrl              String?  @db.Text
  geography           String   @db.Text
  
  // Data Kependudukan
  populationTotal     Int      @default(0)
  populationMale      Int      @default(0)
  populationFemale    Int      @default(0)
  populationFamilies  Int      @default(0)
  
  // Struktur Organisasi
  structureImageUrl   String?
  
  // Konten Lainnya
  potential           String   @db.Text
  organizations       String   @db.Text
  facilities          String   @db.Text
  achievements        String   @db.Text
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum BudgetType {
  REVENUE
  EXPENDITURE
}

model VillageBudget {
  id                          String         @id @default(cuid())
  year                        Int            @unique
  totalRevenueBudget          Float          @default(0)
  totalRevenueRealization     Float          @default(0)
  totalExpenditureBudget      Float          @default(0)
  totalExpenditureRealization Float          @default(0)
  
  items                       BudgetDetail[]
  
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
}

model BudgetDetail {
  id                String        @id @default(cuid())
  budgetId          String
  budget            VillageBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  
  type              BudgetType
  category          String
  amountBudget      Float         @default(0)
  amountRealization Float         @default(0)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}